{
  "name": "productfeeling",
  "version": "0.1.0",
  "description": "Emotion-aware product design skills for AI agents — companions to Impeccable and DocSlime",
  "keywords": [
    "product-design",
    "emotion",
    "ux",
    "skills",
    "ai",
    "claude",
    "cursor",
    "impeccable",
    "chatgpt"
  ],
  "license": "AGPL-3.0-or-later",
  "author": "David Spencer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DecisionNerd/ProductFeeling.git"
  },
  "type": "module",
  "bin": {
    "productfeeling": "cli/bin/cli.js"
  },
  "files": [
    "skill/",
    "plugin/",
    ".claude-plugin/",
    "chatgpt/",
    "cli/",
    "scripts/",
    ".productfeeling/config.json",
    ".productfeeling/FEELING.template.md",
    "LICENSE",
    "NOTICE.md"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "version:check": "node scripts/check-version.mjs",
    "version:set": "node scripts/set-version.mjs",
    "build": "node scripts/build.mjs",
    "build:dist": "node scripts/build.mjs dist",
    "test:cli-install": "node scripts/test-cli-install.mjs",
    "docs:prepare": "node scripts/prepare-docs-site.mjs",
    "docs:dev": "npm run docs:prepare && astro dev",
    "docs:check": "npm run docs:prepare && astro check",
    "docs:site": "npm run version:check && npm run docs:prepare && astro check && astro build && node scripts/check-docs-site.mjs",
    "test": "npm run version:check && npm run test:cli-install && npm run docs:site"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/starlight": "0.41.3",
    "astro": "7.0.7",
    "typescript": "6.0.3"
  }
}
